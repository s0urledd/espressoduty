# ── Validators ──────────────────────────────────────────────────────────────
# Comma-separated BLS verification keys (BLS_VER_KEY~...).
# An entry can carry a display label: MyNode=BLS_VER_KEY~...
MAINNET_VALIDATORS=
TESTNET_VALIDATORS=

# ── Query endpoints ─────────────────────────────────────────────────────────
# First entry is primary; the rest are automatic failover targets.
MAINNET_QUERY_NODES=https://query.main.net.espresso.network/v1
TESTNET_QUERY_NODES=

# Optional: your own node's query service. Enables local-down and
# sync-lag checks.
LOCAL_NODE_URL=

# ── Thresholds ──────────────────────────────────────────────────────────────
# Vote participation rate (0.0-1.0) per epoch.
VOTE_WARN=0.90
VOTE_CRITICAL=0.50
# Proposal participation in leader slots.
PROPOSAL_WARN=0.80
# Participation drop between two consecutive polls that fires the early
# "participation is dropping" warning even above VOTE_WARN.
TREND_DROP=0.05
# Seconds without a decide before the chain counts as stalled.
DECIDE_STALL_SEC=60
# Blocks the local node may trail the network before a lag warning.
HEIGHT_LAG_BLOCKS=20
# Suppress absolute-rate alerts for this many minutes after an epoch
# rollover (a fresh epoch's rate is meaningless on a few samples).
EPOCH_MIN_SAMPLE_MIN=10
# Minimum minutes between repeats of the same alert.
ALERT_COOLDOWN_MIN=30

# ── Polling ─────────────────────────────────────────────────────────────────
# Participation / stake-table poll.
POLL_INTERVAL_SEC=60
# Lightweight status poll (block height, time-since-last-decide) that
# drives the live dashboard and stall detection.
STATUS_POLL_INTERVAL_SEC=10
# 'on' enables endpoint offline/stale/failover/all-offline alerts.
QUERY_HEALTH_ALERTS=off
# Epochs kept in the dashboard history table.
EPOCH_HISTORY_LENGTH=28

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3030
HOSTNAME=0.0.0.0

# ── Alert channels (configure any subset) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
# Consecutive critical polls before PagerDuty is paged.
PAGERDUTY_THRESHOLD=3
