# Validators — Label=0xL1address or Label=BLS_VER_KEY~... (Label= optional).
# An address is resolved to its BLS key automatically on the first poll.
MAINNET_VALIDATORS=

# Data source — public query service (comma-separate extras for failover)
QUERY_NODE=https://query.main.net.espresso.network/v1
# Your own node's query service, if it runs one. Enables the local-down
# and sync-lag checks; leave empty for a node without the query module.
LOCAL_NODE_URL=

# Alert rule — leader duty. The proposal rate only moves when your
# validator IS leader: a falling poll = missed leader slot, a rising
# poll = successful proposal (resets the streak).
CONSECUTIVE_MISSES_WARN=3     # missed slots in a row -> Telegram / Slack / Discord
CONSECUTIVE_MISSES_CRIT=5     # missed slots in a row -> PagerDuty

# Local node monitoring (only if LOCAL_NODE_URL is set)
LOCAL_DOWN_FAILS=5            # consecutive failed status polls before "down"
HEIGHT_LAG_BLOCKS=50          # local behind network by more than this warns
LOCAL_DOWN_PAGE_MIN=10        # minutes down/stuck before PagerDuty is paged
STUCK_AFTER_MIN=5             # minutes without view progress before stuck alert

# Polling
POLL_INTERVAL_SEC=60

# Dead man's switch — a GET fires here after every successful poll, so the
# receiving service (healthchecks.io, Uptime Kuma, ...) alerts you when
# espressoduty itself stops. Empty = off.
HEARTBEAT_URL=

# Persistence — alert counters and the dashboard grid survive restarts
STATE_FILE=./state.json

# Server
PORT=3030

# Channels (configure any subset)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
