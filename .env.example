# ── Validators ──────────────────────────────────────────────────────────────
# Comma-separated BLS verification keys (BLS_VER_KEY~...).
# An entry can carry a display label: MyNode=BLS_VER_KEY~...
MAINNET_VALIDATORS=
TESTNET_VALIDATORS=

# ── Data sources ────────────────────────────────────────────────────────────
# Your own node's query service. Enables the local-down and sync-lag
# checks, and serves status reads (height, last decide) first. It is NOT
# used for participation metrics except as a last resort: participation
# is subjective per node, and the public view below is the one closest
# to what delegators see.
LOCAL_NODE_URL=

# Public query endpoints (first = primary; participation and identity
# are always read from these, in order).
MAINNET_QUERY_NODES=https://query.main.net.espresso.network/v1
TESTNET_QUERY_NODES=

# ── Thresholds ──────────────────────────────────────────────────────────────
# Missed slots, the metric Espresso's own dashboard leads with:
# missed = 1 - proposal_participation. Alerts when it rises ABOVE these.
# 0.50 = warn when more than half of the leader slots are missed.
MISSED_WARN=0.50
MISSED_CRITICAL=0.90
# Vote participation rate (0.0-1.0), secondary signal. Alerts when it
# falls BELOW these. Chat only, never pages on its own.
VOTE_WARN=0.90
VOTE_CRITICAL=0.50
# Seconds without a decide before the chain counts as stalled.
DECIDE_STALL_SEC=60
# Blocks the local node may trail the network before a lag warning.
HEIGHT_LAG_BLOCKS=20
# Minimum minutes between repeats of the same alert.
ALERT_COOLDOWN_MIN=30

# ── Polling ─────────────────────────────────────────────────────────────────
# Participation / stake-table poll.
POLL_INTERVAL_SEC=60
# Lightweight status poll (block height, time-since-last-decide) that
# drives the live dashboard and stall detection.
STATUS_POLL_INTERVAL_SEC=10

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3030
HOSTNAME=0.0.0.0

# ── Alert channels (configure any subset) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
# Consecutive critical polls before PagerDuty is paged.
PAGERDUTY_THRESHOLD=3
