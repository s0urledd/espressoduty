{
  "name": "espressoduty",
  "version": "0.1.0",
  "private": true,
  "description": "Uptime monitoring and alerting for Espresso Network validators",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 3030",
    "build": "next build",
    "postbuild": "cp -r .next/static .next/standalone/.next/static",
    "start": "node -r dotenv/config .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
